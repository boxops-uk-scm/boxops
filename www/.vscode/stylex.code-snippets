{
  "styles.ts": {
    "prefix": "stylex",
    "body": [
      "import '../tokens.stylex.ts';",
      "import './vars.stylex.ts';",
      "",
      "import * as stylex from '@stylexjs/stylex';",
      "import { vars } from './vars.stylex.ts';",
      "",
      "export const styles = stylex.create({",
      "  ${1:base}: {",
      "    $0",
      "  },",
      "});",
    ],
  },
  "variants.ts": {
    "prefix": "stylex-variants",
    "body": [
      "import '../tokens.stylex.ts';",
      "import './vars.stylex.ts';",
      "",
      "import * as stylex from '@stylexjs/stylex';",
      "import { vars } from './vars.stylex.ts';",
      "",
      "export const variants = stylex.create({",
      "  ${1:default}: {",
      "    $0",
      "  },",
      "});",
    ],
  },
  "Component.tsx": {
    "prefix": "stylex-component",
    "body": [
      "import * as stylex from '@stylexjs/stylex';",
      "import { variants } from './variants';",
      "import { styles } from './styles';",
      "import { forwardRef } from 'react';",
      "",
      "export interface Props extends React.HTMLAttributes<${1:HTMLDivElement}> {",
      "  variant?: keyof typeof variants;",
      "  xstyle?: stylex.StyleXStyles;",
      "}",
      "",
      "const $TM_FILENAME_BASE = forwardRef<${1:HTMLDivElement}, Props>(",
      "  ({ variant = 'default', xstyle, ...props }, ref) => (",
      "    <${2:div}",
      "      ref={ref}",
      "      {...stylex.props(",
      "        styles.base,",
      "        variant && variants[variant],",
      "        xstyle,",
      "      )}",
      "      {...props} />",
      "  ),",
      ");",
      "",
      "$TM_FILENAME_BASE.displayName = '$TM_FILENAME_BASE';",
      "",
      "export default $TM_FILENAME_BASE;",
    ],
  },
}
