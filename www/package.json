{
  "name": "www",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "apps/*",
    "@repo/*",
    "@boxops/*"
  ],
  "scripts": {
    "lint": "eslint -c eslint.config.mjs . --max-warnings=0",
    "build": "yarn lint && yarn workspaces foreach -Apt run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stylexjs/eslint-plugin": "^0.18.1",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "relay-compiler": "^20.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "dependenciesMeta": {
    "react@19.2.4": {
      "unplugged": true
    },
    "react-dom@19.2.4": {
      "unplugged": true
    }
  }
}
